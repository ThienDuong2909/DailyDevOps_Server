# Server Configuration
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1
TRUST_PROXY=false

# Database
DATABASE_URL="mysql://user:password@localhost:3306/devopsblog"

# JWT Secrets - MUST be changed in production! App will refuse to start without them.
JWT_ACCESS_SECRET=your-access-secret-key-here-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-here-change-in-production
JWT_MFA_SECRET=your-mfa-challenge-secret-key-here-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_MFA_CHALLENGE_EXPIRES_IN=10m

# CORS - supports comma-separated origins
# Example production value:
# CORS_ORIGIN=http://localhost:3000,https://dailydevops.blog,https://www.dailydevops.blog
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Swagger
SWAGGER_ENABLED=true

# Background jobs
SCHEDULED_PUBLISH_INTERVAL_MS=30000

# Public app URL
APP_URL=http://localhost:3000

# SMTP Email
SMTP_HOST=mail.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=mailer@example.com
SMTP_PASS=your-mail-password
CONTACT_INBOX=team@example.com
EMAIL_FROM="DevOps Daily <mailer@example.com>"

# S3-Compatible Object Storage
S3_ENDPOINT=https://your-object-storage-endpoint.example.com
S3_REGION=auto
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key

# Sentry
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Logging
# LOG_FORMAT supports: pretty, json
LOG_FORMAT=pretty
# Skip noisy Kubernetes /health probe logs by default
LOG_SKIP_HEALTH=true
# Chỉ log các request /api/* để dễ đọc khi chạy production
LOG_ONLY_API=true
# Gemini AI
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_TEXT_MODEL=gemini-3-flash-preview
