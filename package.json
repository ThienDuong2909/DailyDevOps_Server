{
  "name": "devops-blog-server-nodejs",
  "version": "1.0.0",
  "description": "DevOps Blog Backend API - Node.js/Express",
  "main": "src/server.js",
  "author": "DevOps Team",
  "private": true,
  "license": "MIT",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node prisma/seed.js",
    "prisma:migrate:post-editor": "node prisma/migrate-post-editor-structure.js",
    "prisma:migrate:post-translations": "node prisma/migrate-post-translations.js",
    "prisma:backfill:post-editor": "node prisma/backfill-post-editor-content.js",
    "prisma:reset": "prisma migrate reset",
    "seed:posts": "node prisma/seed-posts.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:coverage": "jest --forceExit --detectOpenHandles --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1021.0",
    "@aws-sdk/lib-storage": "^3.1021.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.8.0",
    "@sentry/node": "^10.47.0",
    "adm-zip": "^0.5.17",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "marked": "^17.0.5",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-html-parser": "^7.1.0",
    "nodemailer": "^8.0.4",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "slugify": "^1.6.6",
    "speakeasy": "^2.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.0.2",
    "prisma": "^5.8.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "lcov",
      "text",
      "text-summary"
    ],
    "collectCoverageFrom": [
      "src/modules/posts/posts.image-generator.js",
      "src/modules/posts/posts.formatter.js",
      "src/modules/posts/posts.translator.js",
      "src/modules/**/*.validation.js",
      "src/common/middleware/validation.middleware.js",
      "!src/modules/**/*.service.js",
      "!src/modules/**/*.routes.js",
      "!src/modules/**/*.helpers.js",
      "!src/modules/**/*.queries.js",
      "!src/modules/**/*.repository.js",
      "!src/modules/seo/**",
      "!src/modules/settings/**",
      "!src/server.js",
      "!src/app.js",
      "!src/config/**",
      "!src/common/http/**",
      "!src/common/errors/**",
      "!src/common/observability/**",
      "!src/common/middleware/auth.middleware.js",
      "!src/common/middleware/error.middleware.js",
      "!src/common/middleware/logger.middleware.js",
      "!src/database/**",
      "!src/middlewares/**",
      "!src/utils/metrics.js",
      "!src/utils/prisma.js",
      "!node_modules/**"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js",
      "**/*.test.js"
    ]
  }
}
